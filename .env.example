# ── Supabase (obrigatório) ────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Mercado Pago (obrigatório para pagamentos) ────────────────────────────────
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Admin (opcional) ──────────────────────────────────────────────────────────
# E-mail do usuário admin criado no painel Supabase Auth
VITE_ADMIN_EMAIL=admin@seudominio.com.br

# ─────────────────────────────────────────────────────────────────────────────
# Segredos das Edge Functions — configurar em Supabase > Settings > Secrets
# NÃO colocar no .env — apenas documentado aqui para referência
# ─────────────────────────────────────────────────────────────────────────────
# MP_ACCESS_TOKEN=APP_USR-0000000000000000-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
# MP_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   <- OBRIGATÓRIO para segurança do webhook
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=contato@seudominio.com.br
# SITE_URL=https://www.seusite.com.br              <- usado para restringir CORS
